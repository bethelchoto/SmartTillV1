## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## Get latest from https://github.com/github/gitignore/blob/main/VisualStudio.gitignore

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (DotSettings)
*.csproj.DotSettings.user
*.vbproj.DotSettings.user
*.vcxproj.DotSettings.user

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
bld/
[Bb]in/
[Oo]bj/
[Ll]og/
[Vv][Ss][Ll][Ss][Cc][Oo][Nn][Ff][Ii][Gg]/

# Visual Studio 2015/2017 cache/options directory
.vs/
# Uncomment if you have tasks that create the project's static files in wwwroot
#wwwroot/

# Visual Studio 2017 auto generated files
Generated\ Files/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml
nunit-agent.log

# Build logs
*.log

# StyleCop
StyleCopReport.xml

# Files built by Visual Studio
*.lastcodeanalysissucceeded
*.NetRequestHandler.diag
*.ruleset.bak
*.staticlog
*.tdduser
*.token.bak
*.trx
*.user
*.user_suffix
*.vsp
*.vspx
*.sap
*.psess
*.vshost.exe
*.vshost.exe.config
*.vshost.exe.manifest
*.xml
*.cache
*.temp
*.tmp
*.tlog
*.unsuccessfulbuild
*.xdc

# NuGet Packages
*.nupkg
# NuGet Symbol Packages
*.snupkg
# The packages folder can be ignored because of PackageRestore
**/[Pp]ackages/*
# except build/, which is used as an MSBuild target.
!**/[Pp]ackages/build/
# Uncomment if using NuGet repositories to store project specific packages (not recommended)
#!**/[Pp]ackages/

# Microsoft Azure Build Output
csx/
*.cscfg
*.csdef

# Node.js
node_modules/
npm-debug.log
yarn-error.log

# Typescript
*.tslog

# SQL Server files
*.mdf
*.ldf
*.ndf

# Other
*.suo
*.user
*.userosscache
*.sln.docstates
*.opensdf
*.sdf
*.sublime-project
*.sublime-workspace
*.DS_Store
*.swp
*.bak
*.orig
*~
# End of Visual Studio ignore.
