<Window x:Class="MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SmartTill.V2"
        xmlns:vm="clr-namespace:SmartTill.V2.ViewModels"
        xmlns:views="clr-namespace:SmartTill.V2.Views"
        mc:Ignorable="d"
        Title="SmartTill - POS System" Height="800" Width="1300"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        
        <!-- Navigation Templates -->
        <DataTemplate DataType="{x:Type vm:UserManagementViewModel}">
            <local:UserManagementView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ProductManagementViewModel}">
            <local:ProductManagementView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:POSViewModel}">
            <local:POSView />
        </DataTemplate>
        
        <!-- Style for Sidebar Buttons -->
        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="25,12"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3D2A6D"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SubMenuButtonStyle" TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
            <Setter Property="Padding" Value="50,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Foreground" Value="#CCC"/>
        </Style>
    </Window.Resources>

    <Grid Background="#F0F2F5">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar Navigation -->
        <Border Grid.Column="0" Background="#2C1A4D">
            <DockPanel>
                <!-- User Info Header -->
                <StackPanel DockPanel.Dock="Top" Margin="20,30,20,40">
                    <Ellipse Width="70" Height="70" Fill="#3D2A6D" HorizontalAlignment="Center">
                        <!-- Placeholder for User Icon -->
                    </Ellipse>
                    <TextBlock Text="{Binding UserDisplayName}" Foreground="White" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,15,0,0"/>
                    <TextBlock Text="{Binding UserRoleDisplay}" Foreground="#AAA" FontSize="12" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Navigation Links -->
                <ScrollViewer DockPanel.Dock="Top" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Button Content="Dashboard" Style="{StaticResource SidebarButtonStyle}" Command="{Binding ShowDashboardCommand}"/>
                        
                        <Button Content="POS Terminal" Style="{StaticResource SidebarButtonStyle}" Command="{Binding ShowPOSCommand}" Background="#3D2A6D"/>
                        
                        <!-- Products Expandable Menu -->
                        <Grid Visibility="{Binding IsManager, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <Button Style="{StaticResource SidebarButtonStyle}" Command="{Binding ToggleProductsMenuCommand}">
                                    <Grid Width="190">
                                        <TextBlock Text="Products" VerticalAlignment="Center"/>
                                        <TextBlock Text="⌵" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="18"/>
                                    </Grid>
                                </Button>
                                
                                <StackPanel Visibility="{Binding IsProductsMenuExpanded, Converter={StaticResource BoolToVis}}">
                                    <Button Content="Category Management" Style="{StaticResource SubMenuButtonStyle}" Command="{Binding ShowCategoryManagementCommand}"/>
                                    <Button Content="Product Management" Style="{StaticResource SubMenuButtonStyle}" Command="{Binding ShowProductManagementCommand}"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                        
                        <Button Content="Sales History" Style="{StaticResource SidebarButtonStyle}" 
                                Visibility="{Binding IsManager, Converter={StaticResource BoolToVis}}"/>
                        
                        <Button Content="User Management" Style="{StaticResource SidebarButtonStyle}" 
                                Command="{Binding ShowUserManagementCommand}"
                                Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVis}}"/>
                        
                        <Button Content="Store Settings" Style="{StaticResource SidebarButtonStyle}"
                                Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- Logout at Bottom -->
                <Button DockPanel.Dock="Bottom" Content="Log Out" Style="{StaticResource SidebarButtonStyle}" VerticalAlignment="Bottom" Command="{Binding LogoutCommand}" Margin="0,0,0,20"/>
            </DockPanel>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="70"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top Header Bar -->
            <Border Grid.Row="0" Background="White" BorderBrush="#EEE" BorderThickness="0,0,0,1">
                <Grid Margin="30,0">
                    <TextBlock Text="Management Console" VerticalAlignment="Center" FontSize="20" FontWeight="SemiBold" Foreground="#2C1A4D"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Status}" Foreground="#888" VerticalAlignment="Center" Margin="0,0,20,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Dynamic Content Control -->
            <ContentControl Grid.Row="1" Content="{Binding CurrentView}"/>
            <Grid Grid.Row="1" Visibility="{Binding CurrentView, Converter={x:Static views:NullToVisibilityConverter.Instance}, ConverterParameter=Inverse}">
                <!-- Default Dashboard Content -->
                <ScrollViewer Margin="30">
                    <StackPanel>
                        <!-- Summary Cards Row (Admins/Managers Only) -->
                        <UniformGrid Columns="4" Margin="0,0,0,30" Visibility="{Binding IsManager, Converter={StaticResource BoolToVis}}">
                            <!-- (Existing Cards) -->
                            <Border Background="#4CAF50" CornerRadius="8" Height="100" Margin="0,0,15,0" Padding="20">
                                <StackPanel>
                                    <TextBlock Text="DAILY SALES" Foreground="White" FontSize="12" FontWeight="Bold"/>
                                    <TextBlock Text="0.00" Foreground="White" FontSize="28" FontWeight="Bold" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#F44336" CornerRadius="8" Height="100" Margin="0,0,15,0" Padding="20">
                                <StackPanel>
                                    <TextBlock Text="PRODUCT LINE" Foreground="White" FontSize="12" FontWeight="Bold"/>
                                    <TextBlock Text="2" Foreground="White" FontSize="28" FontWeight="Bold" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#00BCD4" CornerRadius="8" Height="100" Margin="0,0,15,0" Padding="20">
                                <StackPanel>
                                    <TextBlock Text="STOCK ON HAND" Foreground="White" FontSize="12" FontWeight="Bold"/>
                                    <TextBlock Text="230" Foreground="White" FontSize="28" FontWeight="Bold" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#FFC107" CornerRadius="8" Height="100" Padding="20">
                                <StackPanel>
                                    <TextBlock Text="CRITICAL ITEMS" Foreground="White" FontSize="12" FontWeight="Bold"/>
                                    <TextBlock Text="0" Foreground="White" FontSize="28" FontWeight="Bold" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <TextBlock Text="{Binding UserDisplayName, StringFormat='Welcome, {0}!'}" FontSize="24" FontWeight="Bold" Foreground="#2C1A4D" Margin="0,20,0,10"/>
                        
                        <!-- Welcome Messages -->
                        <TextBlock Text="You are logged in as an Administrator. You have full access to system management and reports." 
                                   Foreground="#888" Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVis}}"/>
                        <TextBlock Text="Welcome to your SmartTill POS terminal. Use the sidebar to access permitted tasks." 
                                   Foreground="#888" Visibility="{Binding IsTailor, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Window>