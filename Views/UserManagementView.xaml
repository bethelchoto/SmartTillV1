<UserControl x:Class="UserManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SmartTill.V2"
             xmlns:views="clr-namespace:SmartTill.V2.Views"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="900"
             Background="White">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Page Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,30">
            <TextBlock Text="User Management" FontSize="28" FontWeight="Bold" Foreground="#2C1A4D"/>
            <TextBlock Text="Add, edit, or remove system users and set their permissions." Foreground="#888" Margin="0,5,0,0"/>
        </StackPanel>

        <!-- Action Bar -->
        <Border Grid.Row="1" Background="#F8F9FA" Padding="20,15" CornerRadius="8" Margin="0,0,0,20">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <Button Content="+ Create New User" Background="#2C1A4D" Foreground="White" Padding="20,8" FontWeight="Bold" Command="{Binding ToggleAddUserFormCommand}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
                
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBox Width="250" Padding="10,5" VerticalContentAlignment="Center" d:Text="Search users..."/>
                    <Button Content="Refresh" Background="White" BorderBrush="#CCC" BorderThickness="1" Foreground="#2C1A4D" Margin="10,0,0,0" Padding="15,5" Command="{Binding RefreshCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Create User Form (Expands when needed) -->
        <Border Grid.Row="2" Background="#F0F2F5" CornerRadius="8" Padding="20" Margin="0,0,0,25" Visibility="{Binding IsAddUserFormVisible, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <TextBlock Text="Add New System User" FontWeight="Bold" FontSize="16" Margin="0,0,0,15" Foreground="#2C1A4D"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" Margin="0,0,15,0">
                        <TextBlock Text="Username" Margin="0,0,0,5" Foreground="#555"/>
                        <TextBox Text="{Binding NewUsername, UpdateSourceTrigger=PropertyChanged}" Padding="10,8"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="1" Margin="0,0,15,0">
                        <TextBlock Text="Password" Margin="0,0,0,5" Foreground="#555"/>
                        <TextBox Text="{Binding NewPassword, UpdateSourceTrigger=PropertyChanged}" Padding="10,8"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="User Role" Margin="0,0,0,5" Foreground="#555"/>
                        <ComboBox SelectedItem="{Binding SelectedRole}" Padding="10,5">
                            <ComboBoxItem Content="Admin"/>
                            <ComboBoxItem Content="Manager"/>
                            <ComboBoxItem Content="Tailor"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>
                
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                    <Button Content="Cancel" Command="{Binding ToggleAddUserFormCommand}" Background="Transparent" Foreground="#555" Margin="0,0,15,0" Padding="15,5"/>
                    <Button Content="Save User" Command="{Binding SaveUserCommand}" Background="#2C1A4D" Foreground="White" Padding="25,8" FontWeight="Bold">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
                
                <TextBlock Text="{Binding FormErrorMessage}" Foreground="Red" Margin="0,10,0,0" HorizontalAlignment="Center" Visibility="{Binding FormErrorMessage, Converter={x:Static views:NullToVisibilityConverter.Instance}}"/>
            </StackPanel>
        </Border>

        <!-- Users DataGrid -->
        <Border Grid.Row="3" Background="White" BorderBrush="#EEE" BorderThickness="1" CornerRadius="8">
            <DataGrid ItemsSource="{Binding Users}" SelectedItem="{Binding SelectedUser}" AutoGenerateColumns="False" CanUserAddRows="False" GridLinesVisibility="None" Background="Transparent" BorderThickness="0" RowHeight="50" FontSize="14">
                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F8F9FA"/>
                        <Setter Property="Foreground" Value="#2C1A4D"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="Padding" Value="10,12"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        <Setter Property="BorderBrush" Value="#EEE"/>
                    </Style>
                    <Style TargetType="DataGridCell">
                        <Setter Property="BorderThickness" Value="0"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#E9ECEF"/>
                                <Setter Property="Foreground" Value="Black"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.Resources>
                
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                    <DataGridTextColumn Header="USERNAME" Binding="{Binding Username}" Width="*"/>
                    <DataGridTextColumn Header="ROLE" Binding="{Binding Role}" Width="150"/>
                    <DataGridTextColumn Header="CREATED AT" Binding="{Binding CreatedAt, StringFormat=\{0:dd MMM yyyy\}}" Width="180"/>
                    
                    <DataGridTemplateColumn Header="ACTIONS" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Content="Edit" Foreground="#007BFF" Background="Transparent" BorderThickness="0" Cursor="Hand" Margin="0,0,10,0"/>
                                    <Button Content="Delete" Foreground="#D11111" Background="Transparent" BorderThickness="0" Cursor="Hand" Command="{Binding DataContext.DeleteUserCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>