<UserControl x:Class="POSView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:SmartTill.V2"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d" 
             d:DesignHeight="850" d:DesignWidth="1200"
             Background="#EDF1F7">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <!-- Modern Colors -->
        <Color x:Key="PrimaryPurple">#2C1A4D</Color>
        <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryPurple}"/>
        
        <!-- Drop Shadow -->
        <DropShadowEffect x:Key="SoftShadow" BlurRadius="20" ShadowDepth="2" Opacity="0.1" Color="Black"/>

        <!-- Payment Method Toggle Style -->
        <Style x:Key="PaymentToggleStyle" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" Background="#F0F0F0" CornerRadius="4" Margin="0,0,5,0" Padding="12,8">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock x:Name="icon" Text="💵" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <ContentPresenter VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#4CAF50"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <!-- Custom icons based on content -->
                            <DataTrigger Binding="{Binding Content, RelativeSource={RelativeSource Self}}" Value="Card">
                                <Setter TargetName="icon" Property="Text" Value="💳"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Content, RelativeSource={RelativeSource Self}}" Value="EcoCash">
                                <Setter TargetName="icon" Property="Text" Value="📱"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BottomActionButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <ContentPresenter VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernActionButton" TargetType="Button">
            <Setter Property="Background" Value="#4CAF50"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="5,10,10,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Navigation Status Bar -->
        <Border Grid.Row="0" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="POS Terminal" FontWeight="Bold" FontSize="18" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,15,0"/>
                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="10,0"/>
                <TextBlock Text="Welcome," Foreground="#444" VerticalAlignment="Center"/>
                <TextBlock Text="Jane Doe" FontWeight="SemiBold" Margin="5,0,15,0" VerticalAlignment="Center"/>
                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="10,0"/>
                <TextBlock Text="Branch A" Margin="5,0,15,0" VerticalAlignment="Center"/>
                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="10,0"/>
                <TextBlock Text="Terminal Online" Foreground="#2E7D32" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="10,0"/>
                <TextBlock Text="{Binding Source={x:Static sys:DateTime.Now}, StringFormat=t}" FontWeight="Bold" Margin="0,0,15,0" VerticalAlignment="Center"/>
                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="10,0"/>
                <TextBlock Text="Sale #: 1001" FontWeight="SemiBold" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Main Workspace -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="380"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Search and Cart -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Search Bar with Dropdown -->
                <Grid Grid.Row="0" Margin="0,0,10,10">
                    <Border Background="White" CornerRadius="12" Padding="15,5" Effect="{StaticResource SoftShadow}">
                        <DockPanel>
                            <TextBlock Text="🔍" VerticalAlignment="Center" Margin="0,0,15,0" Foreground="#666"/>
                            <TextBox BorderThickness="0" FontSize="18" VerticalAlignment="Center" 
                                     Text="{Binding BarcodeInput, UpdateSourceTrigger=PropertyChanged}"
                                     GotFocus="Search_GotFocus">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Enter" Command="{Binding QuickAddCommand}"/>
                                </TextBox.InputBindings>
                            </TextBox>
                        </DockPanel>
                    </Border>
                    
                    <!-- Search Results Dropdown -->
                    <Popup IsOpen="{Binding IsSearchDropdownOpen}" StaysOpen="False" AllowsTransparency="True" Placement="Bottom" Width="700">
                        <Border Background="White" CornerRadius="0,0,12,12" Effect="{StaticResource SoftShadow}" Margin="0,0,15,0">
                            <ItemsControl ItemsSource="{Binding FilteredInventory}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Command="{Binding DataContext.AddItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}" Background="Transparent" BorderThickness="0,0,0,1" BorderBrush="#EEE" HorizontalContentAlignment="Stretch">
                                            <Border Padding="15,10">
                                                <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="16" Foreground="{StaticResource PrimaryBrush}"/>
                                                    <TextBlock Text="{Binding Barcode}" FontSize="12" Foreground="#444"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="1" Text="{Binding Price, StringFormat=C2}" FontWeight="Bold" FontSize="18" VerticalAlignment="Center" Foreground="{StaticResource PrimaryBrush}"/>
                                                </Grid>
                                            </Border>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </Popup>
                </Grid>

                <!-- Cart Grid -->
                <Border Grid.Row="1" Background="White" CornerRadius="15" Margin="0,0,15,0" Effect="{StaticResource SoftShadow}">
                    <DataGrid ItemsSource="{Binding CartItems}" AutoGenerateColumns="False" CanUserAddRows="False" GridLinesVisibility="None" Background="Transparent" BorderThickness="0" HeadersVisibility="Column" RowHeight="70" SelectionUnit="FullRow">
                        <DataGrid.Resources>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Foreground" Value="#444"/>
                                <Setter Property="Padding" Value="20,10"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="#EEE"/>
                            </Style>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="ITEM" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel VerticalAlignment="Center" Margin="20,0">
                                            <TextBlock Text="{Binding ProductName}" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}"/>
                                            <TextBlock Text="{Binding ProductId, StringFormat='SKU: {0}'}" FontSize="11" Foreground="#444"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="PRICE" Width="140">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button Content="-" Width="25" Height="25" Command="{Binding DataContext.DecrementQtyCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" Background="#F0F0F0" BorderThickness="0" Margin="0,0,10,0"/>
                                            <TextBlock Text="{Binding Quantity}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                            <Button Content="+" Width="25" Height="25" Command="{Binding DataContext.IncrementQtyCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}" Background="#F0F0F0" BorderThickness="0" Margin="10,0,0,0"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTemplateColumn Header="DISC %" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ComboBox SelectedItem="{Binding DiscountPercent}" Width="70" VerticalAlignment="Center">
                                            <sys:Decimal>0</sys:Decimal>
                                            <sys:Decimal>5</sys:Decimal>
                                            <sys:Decimal>10</sys:Decimal>
                                            <sys:Decimal>20</sys:Decimal>
                                        </ComboBox>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="TOTAL" Binding="{Binding Total, StringFormat=C2}" Width="120">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="TextAlignment" Value="Right"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Margin" Value="0,0,20,0"/>
                                        <Setter Property="Foreground" Value="{StaticResource PrimaryBrush}"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <DataGridTemplateColumn Width="50">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="🗑" Foreground="Red" FontSize="18" Background="Transparent" BorderThickness="0" Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}" CommandParameter="{Binding}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

            </Grid>

            <!-- Right Sidebar: Payments -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Customer Section -->
                <Border Grid.Row="0" Background="White" CornerRadius="12" Padding="15,10" Margin="0,0,0,10" Effect="{StaticResource SoftShadow}">
                    <StackPanel>
                        <TextBlock Text="Payment" FontWeight="Bold" FontSize="18" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,0,15"/>
                        <Border Background="#F4F7FA" CornerRadius="8" Padding="12" Margin="0,0,0,10">
                            <Grid>
                                <StackPanel>
                                    <TextBlock Text="Walk-in Customer" FontWeight="SemiBold"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                        <TextBlock Text="Loyalty Points: 0" FontSize="11" Foreground="#444" Margin="0,0,15,0"/>
                                        <TextBlock Text="Total Visits: 0" FontSize="11" Foreground="#444"/>
                                    </StackPanel>
                                </StackPanel>
                                <TextBlock Text="Add Customer" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="#2196F3" Cursor="Hand" TextDecorations="Underline"/>
                            </Grid>
                        </Border>

                        <!-- Held Sales List -->
                        <TextBlock Text="Held Sales" FontSize="12" FontWeight="Bold" Foreground="#444" Margin="0,10,0,5"/>
                        <ItemsControl ItemsSource="{Binding HeldSales}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding DataContext.RecallCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding Id}" Background="White" BorderBrush="#EEE" BorderThickness="0,0,0,1" HorizontalContentAlignment="Stretch">
                                        <Border Padding="5">
                                            <Grid>
                                                <TextBlock Text="{Binding Reference}" FontSize="12" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding TotalAmount, StringFormat=C2}" HorizontalAlignment="Right" FontSize="12" Foreground="#2E7D32"/>
                                            </Grid>
                                        </Border>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- Payment Summary and Actions -->
                <Border Grid.Row="1" Background="White" CornerRadius="12" Padding="15,10" Effect="{StaticResource SoftShadow}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/> <!-- Header -->
                            <RowDefinition Height="Auto"/> <!-- Subtotal -->
                            <RowDefinition Height="Auto"/> <!-- Disc -->
                            <RowDefinition Height="Auto"/> <!-- Tax -->
                            <RowDefinition Height="Auto"/> <!-- Spacer -->
                            <RowDefinition Height="Auto"/> <!-- Grand Total -->
                            <RowDefinition Height="Auto"/> <!-- Pay Method Label -->
                            <RowDefinition Height="Auto"/> <!-- Pay Method Buttons -->
                            <RowDefinition Height="Auto"/> <!-- Amount Paid -->
                            <RowDefinition Height="Auto"/> <!-- Change -->
                            <RowDefinition Height="Auto"/> <!-- Spacer reduced -->
                            <RowDefinition Height="Auto"/> <!-- Process Sale -->
                            <RowDefinition Height="Auto"/> <!-- Hold/Abort -->
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Payment Details" FontWeight="Bold" Margin="0,0,0,10" FontSize="15"/>

                        <!-- Row 1: Subtotal -->
                        <Grid Grid.Row="1" Margin="0,0,0,10">
                            <TextBlock Text="Subtotal" Foreground="#444"/>
                            <TextBlock Text="{Binding Subtotal, StringFormat=C2}" HorizontalAlignment="Right" FontWeight="SemiBold"/>
                        </Grid>

                        <!-- Row 2: Discount -->
                        <Grid Grid.Row="2" Margin="0,0,0,10">
                            <TextBlock Text="Discount %" Foreground="#444" VerticalAlignment="Center"/>
                            <TextBox Text="{Binding DiscountRate, UpdateSourceTrigger=PropertyChanged}" Width="70" HorizontalAlignment="Right" Padding="5"/>
                        </Grid>

                        <!-- Row 3: Tax -->
                        <Grid Grid.Row="3" Margin="0,0,0,20">
                            <TextBlock Text="Tax (VAT 15%)" Foreground="#444"/>
                            <TextBlock Text="{Binding TaxAmount, StringFormat=C2}" HorizontalAlignment="Right" FontWeight="SemiBold"/>
                        </Grid>

                        <!-- Row 5: Grand Total -->
                        <Grid Grid.Row="5" Margin="0,0,0,15">
                            <TextBlock Text="GRAND TOTAL" FontWeight="Bold" FontSize="16"/>
                            <TextBlock Text="{Binding TotalAmount, StringFormat=C2}" HorizontalAlignment="Right" FontSize="20" FontWeight="Bold" Foreground="#2E7D32"/>
                        </Grid>

                        <!-- Row 6: Pay Method Label -->
                        <TextBlock Grid.Row="6" Text="Payment Method" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,10"/>

                        <!-- Row 7: Pay Method Buttons -->
                        <UniformGrid Grid.Row="7" Columns="3" Margin="0,0,0,20">
                            <RadioButton Style="{StaticResource PaymentToggleStyle}" Content="Cash" IsChecked="True" GroupName="PayMethod"/>
                            <RadioButton Style="{StaticResource PaymentToggleStyle}" Content="Card" GroupName="PayMethod"/>
                            <RadioButton Style="{StaticResource PaymentToggleStyle}" Content="EcoCash" GroupName="PayMethod"/>
                        </UniformGrid>

                        <!-- Row 8: Amount Paid -->
                        <Grid Grid.Row="8" Margin="0,0,0,10">
                            <TextBlock Text="Amount Paid" Foreground="#444" FontSize="14" VerticalAlignment="Center"/>
                            <TextBox Text="{Binding AmountPaid, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Width="100" HorizontalAlignment="Right" FontSize="16" FontWeight="Bold" Padding="5" TextAlignment="Right"/>
                        </Grid>

                        <!-- Row 9: Change -->
                        <Grid Grid.Row="9" Margin="0,0,0,10">
                            <TextBlock Text="Change Due" Foreground="#444" FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding ChangeDue, StringFormat=C2}" HorizontalAlignment="Right" FontSize="18" FontWeight="Bold" Foreground="#2E7D32"/>
                        </Grid>

                        <!-- Row 11: Process Sale -->
                        <Button Grid.Row="11" Content="PROCESS SALE (F2)" Background="#4CAF50" Foreground="White" Height="42" FontSize="16" FontWeight="Bold" Margin="0,5,0,8" Command="{Binding CheckoutCommand}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Row 12: Hold / Abort -->
                        <Grid Grid.Row="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="HOLD SALE" Background="#FF9800" Foreground="White" Height="40" Margin="0,0,5,0" Command="{Binding HoldCommand}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Button Grid.Column="1" Content="ABORT SALE" Background="#F44336" Foreground="White" Height="40" Margin="5,0,0,0" Command="{Binding AbortCommand}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- Success Toast Notification -->
        <Border Panel.ZIndex="2000"
                VerticalAlignment="Top" HorizontalAlignment="Center"
                Margin="0,20,0,0"
                Visibility="{Binding IsSuccessToastVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                Background="#2E7D32" CornerRadius="12" Padding="24,16"
                Effect="{StaticResource SoftShadow}">
            <Border.RenderTransform>
                <TranslateTransform/>
            </Border.RenderTransform>
            <StackPanel Orientation="Horizontal">
                <Border Background="#4CAF50" CornerRadius="20" Width="36" Height="36" Margin="0,0,14,0">
                    <TextBlock Text="✓" Foreground="White" FontSize="20" FontWeight="Bold"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Sale Successful!" Foreground="White" FontSize="16" FontWeight="Bold"/>
                    <TextBlock Text="{Binding LastSale.TotalAmount, StringFormat='Total: ${0:N2} — Stock updated'}"
                               Foreground="#C8E6C9" FontSize="12" Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Receipt Overlay -->
        <Grid Visibility="{Binding IsReceiptVisible, Converter={StaticResource BooleanToVisibilityConverter}}" Panel.ZIndex="1000">
            <Border Background="#80000000"/>
            <Border Background="White" Width="400" MaxHeight="700" VerticalAlignment="Center" HorizontalAlignment="Center" CornerRadius="10" Padding="30" Effect="{StaticResource SoftShadow}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <!-- Branding -->
                        <StackPanel HorizontalAlignment="Center" Margin="0,0,0,16">
                            <!-- SmartTill Logo Text -->
                            <Border Background="#2C1A4D" CornerRadius="8" Padding="16,8" HorizontalAlignment="Center" Margin="0,0,0,8">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Smart" Foreground="White" FontSize="22" FontWeight="Bold" VerticalAlignment="Center"/>
                                    <TextBlock Text="Till" Foreground="#FF9800" FontSize="22" FontWeight="Bold" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <TextBlock Text="SmartTill Point of Sale" FontWeight="Bold" FontSize="13" HorizontalAlignment="Center" Foreground="#333"/>
                            <TextBlock Text="Tel: +263 77 000 0000" Foreground="#666" FontSize="11" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                            <TextBlock Text="Email: info@smarttill.co.zw" Foreground="#666" FontSize="11" HorizontalAlignment="Center"/>
                        </StackPanel>

                        <TextBlock Text="Tax Invoice" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center" Margin="0,0,0,15"/>

                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Name:" Foreground="#444" FontSize="11"/>
                                <TextBlock Text="{Binding CustomerName}" FontWeight="SemiBold" FontSize="11"/>
                                <TextBlock Text="Invoice No:" Foreground="#444" FontSize="11" Margin="0,5,0,0"/>
                                <TextBlock Text="{Binding LastSale.Id, StringFormat=CS{0}}" FontWeight="SemiBold" FontSize="11"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                <TextBlock Text="Customer Id: #LL93784" Foreground="#444" FontSize="11"/>
                                <TextBlock Text="Date:" Foreground="#444" FontSize="11" Margin="0,5,0,0" HorizontalAlignment="Right"/>
                                <TextBlock Text="{Binding LastSale.SaleDate, StringFormat=\{0:dd.MM.yyyy\}}" FontWeight="SemiBold" FontSize="11" HorizontalAlignment="Right"/>
                            </StackPanel>
                        </Grid>

                        <!-- Items Table -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="20"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto" MinWidth="50"/>
                                <ColumnDefinition Width="Auto" MinWidth="40"/>
                                <ColumnDefinition Width="Auto" MinWidth="60"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="#" FontWeight="Bold" FontSize="11"/>
                            <TextBlock Grid.Column="1" Text="Item" FontWeight="Bold" FontSize="11"/>
                            <TextBlock Grid.Column="2" Text="Price" FontWeight="Bold" FontSize="11" TextAlignment="Right"/>
                            <TextBlock Grid.Column="3" Text="Qty" FontWeight="Bold" FontSize="11" TextAlignment="Center"/>
                            <TextBlock Grid.Column="4" Text="Total" FontWeight="Bold" FontSize="11" TextAlignment="Right"/>
                        </Grid>
                        <Separator Background="#EEE" Margin="0,0,0,10"/>

                        <ItemsControl ItemsSource="{Binding LastSaleDetails}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto" MinWidth="50"/>
                                            <ColumnDefinition Width="Auto" MinWidth="40"/>
                                            <ColumnDefinition Width="Auto" MinWidth="60"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="1" Text="{Binding ProductName}" FontSize="11" TextWrapping="Wrap" Foreground="#222"/>
                                        <TextBlock Grid.Column="2" Text="{Binding UnitPrice, StringFormat=${0:N2}}" FontSize="11" TextAlignment="Right" Foreground="#222"/>
                                        <TextBlock Grid.Column="3" Text="{Binding Quantity}" FontSize="11" TextAlignment="Center" Foreground="#222"/>
                                        <TextBlock Grid.Column="4" Text="{Binding Total, StringFormat=${0:N2}}" FontSize="11" TextAlignment="Right" Foreground="#222"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Separator Background="#EEE" Margin="0,10,0,10"/>

                        <!-- Totals Area -->
                        <Grid HorizontalAlignment="Stretch" Margin="0,0,0,5">
                            <TextBlock Text="Sub Total :" Foreground="#444" FontSize="11"/>
                            <TextBlock Text="{Binding LastSale.Subtotal, StringFormat=${0:N2}}" HorizontalAlignment="Right" FontSize="11" FontWeight="SemiBold"/>
                        </Grid>
                        <Grid HorizontalAlignment="Stretch" Margin="0,0,0,5">
                            <TextBlock Text="Discount :" Foreground="#444" FontSize="11"/>
                            <TextBlock Text="{Binding LastSale.DiscountAmount, StringFormat=-${0:N2}}" HorizontalAlignment="Right" FontSize="11" FontWeight="SemiBold" Foreground="#F44336"/>
                        </Grid>
                        <Grid HorizontalAlignment="Stretch" Margin="0,0,0,5">
                            <TextBlock Text="Tax (15%) :" Foreground="#444" FontSize="11"/>
                            <TextBlock Text="{Binding LastSale.TaxAmount, StringFormat=${0:N2}}" HorizontalAlignment="Right" FontSize="11" FontWeight="SemiBold"/>
                        </Grid>
                        <Grid HorizontalAlignment="Stretch" Margin="0,0,0,5">
                            <TextBlock Text="Total Bill :" Foreground="#444" FontSize="11"/>
                            <TextBlock Text="{Binding LastSale.TotalAmount, StringFormat=${0:N2}}" HorizontalAlignment="Right" FontSize="11" FontWeight="Bold"/>
                        </Grid>
                        <Grid HorizontalAlignment="Stretch" Margin="0,0,0,10">
                            <TextBlock Text="Due :" Foreground="#444" FontSize="11"/>
                            <TextBlock Text="$0.00" HorizontalAlignment="Right" FontSize="11"/>
                        </Grid>

                        <Grid HorizontalAlignment="Stretch" Margin="0,5,0,20">
                            <TextBlock Text="Total Payable :" FontWeight="Bold" FontSize="14" Foreground="#1A237E"/>
                            <TextBlock Text="{Binding LastSale.TotalAmount, StringFormat=${0:N2}}" HorizontalAlignment="Right" FontWeight="Bold" FontSize="16" Foreground="#1A237E"/>
                        </Grid>


                        <TextBlock Text="Thank You For Shopping With Us. Please Come Again" FontSize="10" Foreground="#666" HorizontalAlignment="Center" Margin="0,20,0,20"/>

                        <Button Content="Print Receipt" Background="#FF9800" Foreground="White" Height="40" FontWeight="Bold" Command="{Binding CloseReceiptCommand}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="5">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
